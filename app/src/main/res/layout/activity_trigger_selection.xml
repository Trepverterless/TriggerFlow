<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/select_trigger_type"
            android:textSize="20sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTimeTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/time_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLocationTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/location_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBatteryTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/battery_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnWiFiTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/wifi_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBluetoothTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/bluetooth_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnScreenTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/screen_trigger" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSmsTrigger"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sms_trigger" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>